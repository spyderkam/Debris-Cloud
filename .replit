entrypoint = "main.py"
modules = ["python-3.11"]
hidden = ["generated-icon.png"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "pkg-config", "vim", "xsimd"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"
